<% layout('/layouts/boilerplate') %>

    <body>
        <div class="row ">

            <div class="col-8 offset-2">

                <div class="mt-3">
                    <h3><b>
                            <%= listDetail.title %>


                        </b></h3>

                    <div class="card listing-card" style="position: relative; width: 900px;">
                        <img src="<%= listDetail.image.url %>" alt="" height="500px" width="900px" class="card-img">

                        <div class="card-img-overlay">
                            <div class="over-details">
                                <div class="over-guests">
                                    <p>Guest favourite</p>
                                </div>
                                <i class="fa-solid fa-heart"></i>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

        </div>

        <div class="row">
            <div class="col-8 offset-2 ">

                <p>
                    <%= listDetail.description %>
                </p>

                <p>
                    Category: <%= listDetail.category %>
                </p>

                <p>Price : <%= listDetail.price.toLocaleString('en-IN', { style: 'currency' , currency: 'INR' })%>
                        /night</p>

                <p>Location : <%= listDetail.location %>
                </p>
                <p>Country : <%= listDetail.country %>
                </p>
            </div>
        </div>




        <div class="row mb-5 btns">
            <% if ( currUser && listDetail.owner && listDetail.owner._id.toString()===currUser._id.toString() ) { %>
                <div class="col-8 offset-2 d-flex justify-content-center gap-4">
                    <form method="GET" action="/listings/<%=listDetail._id %>/edit">
                        <button class="btn btn-primary">Edit</button>
                    </form>
                    <form method="POST" action="/listings/<%=listDetail._id%>/?_method=DELETE">
                        <button class="btn btn-danger">Delete</button>
                    </form>
                </div>

                <div class="col-md-6 d-flex justify-content-end">
                </div>
                <% } %>
                
        </div>


        <div class="col-8 offset-2">
            <hr>
            <% if(currUser) {%>
                <h4>Leave a Review</h4>

                <form method="POST" action="/listings/<%= listDetail._id %>/reviews" class="needs-validation"
                    novalidate>
                    <label for="rating" class="form-label">Rating</label>
                    <div class="mb-3 mt-3">
                        <fieldset class="starability-coinFlip">
                            <input type="radio" id="no-rate" class="input-no-rate" name="review[rating]" value="0"
                                checked aria-label="No rating." />
                            <input type="radio" id="first-rate1" name="review[rating]" value="1" />
                            <label for="first-rate1" title="Terrible">1 star</label>
                            <input type="radio" id="first-rate2" name="review[rating]" value="2" />
                            <label for="first-rate2" title="Not good">2 stars</label>
                            <input type="radio" id="first-rate3" name="review[rating]" value="3" />
                            <label for="first-rate3" title="Average">3 stars</label>
                            <input type="radio" id="first-rate4" name="review[rating]" value="4" />
                            <label for="first-rate4" title="Very good">4 stars</label>
                            <input type="radio" id="first-rate5" name="review[rating]" value="5" />
                            <label for="first-rate5" title="Amazing">5 stars</label>
                        </fieldset>

                    </div>

                    <div>
                        <label for="comment" class="form-label">Comments</label>
                        <textarea name="review[comment]" id="comment" cols="38" rows="5" class="form-control"
                            required></textarea>
                        <div class="invalid-feedback">
                            Please add some comments for review
                        </div>
                    </div>


                    <button class="btn btn-outline-dark mt-2 mb-4">Submit</button>
                </form>
                <% } %>


                    <% if(listDetail.reviews.length> 0) { %>
                        <hr>
                        <div class="row">
                            <p><b>All Reviews</b></p>
                            <% for( review of listDetail.reviews) { %>

                                <div class="card col-5 ms-4 mb-3">
                                    <div class="card-body">
                                        <h5 class="card-title"> @<%= review.author.username %>
                                        </h5>
                                        <p class="starability-result" data-rating="<%= review.rating %>"></p>
                                        <p class="card-text">
                                            <%= review.comment %>
                                        </p>

                                        <form method="POST"
                                            action="/listings/<%= listDetail._id %>/reviews/<%= review._id %>?_method=DELETE">
                                            <% if ( review.author.equals(currUser._id) ) {
                                                %>
                                                <button class="btn btn-sm btn-dark">Delete</button>
                                                <% } %>
                                        </form>

                                    </div>
                                </div>
                                <% } %>
                        </div>
                        <% } %>

        </div>
    </body>