<% layout('/layouts/boilerplate') %>

    <body>

        <div class="row mt-3">
            <div class="col-8 offset-2">
                <form method="POST" action="/listings" novalidate class="needs-validation"
                    enctype="multipart/form-data">
                    <h3>Add new Listing</h3>
                    <div class="mb-3">
                        <label for="title" class="form-label">Title</label>
                        <input type="text" class="form-control" name="Listing[title]" placeholder="Add a catchy title" required>
                        <div class="valid-feedback">
                            Looks good!
                        </div>
                    </div>
                    <div class="mb-3">
                        <label for="description" class="form-label">Description</label>
                        <textarea name="Listing[description]" class="form-control" placeholder="enter description"
                            rows="5" cols="21" required></textarea>
                        <div class="invalid-feedback">
                            Enter valid description.
                        </div>
                    </div>
                    <!-- <div class="mb-3">
                        <label for="image" class="form-label">Image link</label>
                        <input type="url" class="form-control" name="Listing[image][url]"
                            placeholder="enter image url/link">
                    </div> -->

                    <div class="mb-3">
                        <label for="image" class="form-label">Upload Image</label>
                        <input type="file" class="form-control" name="Listing[image]" required>
                        <div class="invalid-feedback">
                            Upload valid image.
                        </div>
                    </div>

                    <div class="row">
                        <div class="mb-3 col-md-4">
                            <label for="price" class="form-label">Price</label>
                            <input type="text" class="form-control" name="Listing[price]" placeholder="1500" required>
                            <div class="invalid-feedback">
                                Enter valid price.
                            </div>
                        </div>
                        <div class="mb-3 col-md-4">
                            <label for="category" class="form-label">Select category</label> <br>
                            <Select name="Listing[category]" id="category"> 
                                <% categories.forEach(category => { %>
                                   <option value="<%= category %>"><%= category %></option>
                                <% }) %>
                            </Select>
                            <div class="invalid-feedback">
                                Select category
                            </div>
                            
                        </div>
                        <div class="mb-3 col-md-8">
                            <label for="location" class="form-label">Location</label>
                            <input type="text" class="form-control" name="Listing[location]" placeholder="India"
                                required>
                            <div class="invalid-feedback">
                                Provide a valid Location.
                            </div>
                        </div>
                    </div>
                    <div class="mb-3">
                        <label for="country" class="form-label">Country</label>
                        <input type="text" class="form-control" name="Listing[country]" placeholder="enter country" required>
                        <div class="invalid-feedback">
                            Provide a valid country.
                        </div>
                    </div>

                    <button class="btn btn-primary mb-5">Add</button>

                </form>
            </div>
        </div>

    </body>